{
  "manifest_version": 3,
  "name": "MirrorAgent",
  "version": "1.0.0",
  "description": "Companion extension for MirrorAgent distraction blocker",
  "permissions": ["tabs", "storage", "alarms"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "MirrorAgent",
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
